{
  "name": "@polarityio/vite-plugin-icl",
  "version": "1.0.0",
  "description": "Vite plugin for the Polarity integration framework – transforms web component names into unique names.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup && husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "keywords": [
    "vite",
    "plugin",
    "web-components",
    "polarity"
  ],
  "author": "Polarity.io",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polarityio/vite-plugin-icl.git"
  },
  "homepage": "https://github.com/polarityio/vite-plugin-icl#readme",
  "bugs": {
    "url": "https://github.com/polarityio/vite-plugin-icl/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  }
}
